rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public leaderboard: anyone may read; signed-in (anonymous) players
    // may append well-formed entries. Nothing can be edited or deleted.
    match /scores/{score} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 14
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 9999
        && request.resource.data.mode is string
        && request.resource.data.mode in ['story', 'normal', 'gauntlet'];
      allow update, delete: if false;
    }

    // everything else stays locked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
